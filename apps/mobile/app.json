{
  "name": "TalentFlow AI",
  "slug": "talentflow-ai",
  "version": "1.0.0",
  "orientation": "portrait",
  "icon": "./assets/icon.png",
  "userInterfaceStyle": "automatic",
  "splash": {
    "image": "./assets/splash.png",
    "resizeMode": "contain",
    "backgroundColor": "#2563eb"
  },
  "assetBundlePatterns": ["**/*"],
  "ios": {
    "supportsTablet": true,
    "bundleIdentifier": "com.talentflow.ai",
    "buildNumber": "1"
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#2563eb"
    },
    "package": "com.talentflow.ai",
    "versionCode": 1
  },
  "plugins": [
    "expo-router",
    [
      "expo-camera",
      {
        "cameraPermission": "Allow TalentFlow AI to access your camera for profile photos."
      }
    ],
    [
      "expo-image-picker",
      {
        "photosPermission": "Allow TalentFlow AI to access your photos for profile pictures."
      }
    ]
  ],
  "scheme": "talentflow",
  "extra": {
    "eas": {
      "projectId": "YOUR_EAS_PROJECT_ID"
    }
  }
}
