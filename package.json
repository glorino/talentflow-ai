{
  "name": "talentflow-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "cd packages/database && npx drizzle-kit generate",
    "db:migrate": "cd packages/database && npx drizzle-kit migrate",
    "db:push": "cd packages/database && npx drizzle-kit push",
    "db:seed": "tsx packages/database/src/seed.ts",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
